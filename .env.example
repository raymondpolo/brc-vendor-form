# .env.example
# Rename this file to .env and fill in your actual values.
# DO NOT commit the .env file to version control.
# Flask App
SECRET_KEY='a-very-strong-and-random-secret-key'
DATABASE_URL='sqlite:///site.db' # Or 'postgresql://user:pass@host:port/dbname'

# --- Email Configuration ---
# Replace Flask-Mail settings with the SendGrid API Key
SENDGRID_API_KEY='YOUR_SENDGRID_API_KEY_HERE'
MAIL_DEFAULT_SENDER='Your App Name <your-verified-email@example.com>'

# --- Web Push Notifications ---
# Generate these using `vapid --gen` from the `pywebpush` library
VAPID_PUBLIC_KEY='YOUR_VAPID_PUBLIC_KEY'
VAPID_PRIVATE_KEY='YOUR_VAPID_PRIVATE_KEY'
VAPID_CLAIM_EMAIL='mailto:your-email@example.com'